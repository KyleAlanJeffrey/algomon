{
  "name": "algomon-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "cf:build": "npx @cloudflare/next-on-pages",
    "cf:preview": "npm run cf:build && npx wrangler pages dev .vercel/output/static",
    "cf:deploy": "npm run cf:build && npx wrangler pages deploy .vercel/output/static",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply algomon --local",
    "db:migrate": "wrangler d1 migrations apply algomon",
    "db:studio": "drizzle-kit studio",
    "lint": "next lint",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@cloudflare/next-on-pages": "^1.13.8",
    "@tanstack/react-query": "^5.62.7",
    "@visx/group": "^3.3.0",
    "@visx/scale": "^3.5.0",
    "@visx/text": "^3.3.0",
    "@visx/wordcloud": "^3.3.0",
    "drizzle-orm": "^0.36.4",
    "framer-motion": "^11.13.1",
    "geist": "^1.3.0",
    "next": "^15.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241224.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "drizzle-kit": "^0.28.1",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "wrangler": "^3.101.0"
  }
}
